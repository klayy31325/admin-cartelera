datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  role     String   @default("USER") // e.g. ADMIN
}

model Machine {
  id          Int      @id @default(autoincrement())
  name        String   @unique // e.g. NOVOFLEX, OLYMPIA
  productions Production[]
  targets     Target[]
}

model Client {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  productions Production[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  productions Production[]
}

model DowntimeReason {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  downtimes   Downtime[]
}

model Production {
  id              Int      @id @default(autoincrement())
  machineId       Int
  machine         Machine  @relation(fields: [machineId], references: [id])
  shift           String
  clientId        Int
  client          Client   @relation(fields: [clientId], references: [id])
  productId       Int
  product         Product  @relation(fields: [productId], references: [id])
  date            DateTime
  
  daysWorked      Float
  metersProduced  Float
  averageSpeed    Float
  wasteML         Float
  wasteKG         Float

  jobNumber       String
  repetition      String
  approval        String
  suspension      String

  downtimes       Downtime[]
  createdAt       DateTime @default(now())
}

model Downtime {
  id              Int      @id @default(autoincrement())
  productionId    Int
  production      Production @relation(fields: [productionId], references: [id], onDelete: Cascade)
  reasonId        Int
  reason          DowntimeReason @relation(fields: [reasonId], references: [id])
  minutes         Int
}

model Target {
  id          Int      @id @default(autoincrement())
  machineId   Int
  machine     Machine  @relation(fields: [machineId], references: [id])
  metric      String   // Speed, WasteML, WasteKG
  greenMax    Float
  yellowMax   Float
  @@unique([machineId, metric])
}
